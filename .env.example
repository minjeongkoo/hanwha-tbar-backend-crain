# 복사: .env.example 을 .env 로 복사 후 수정 (.env 는 Git 제외)
# Windows: copy .env.example .env

PORT=3001

# hanwha-tbar-backend-edge 베이스 URL (끝에 / 없이)
EDGE_API_BASE_URL=http://localhost:3000

# Crain용 Realm 파일 경로
# - 상대 경로: 프로젝트에서 npm start 할 때의 현재 작업 디렉터리 기준
# - Windows 예: REALM_PATH=data\crain.realm 또는 REALM_PATH=C:\한화\data\crain.realm
# - mac/Linux 예:
REALM_PATH=../plc-data-agent/data/dev_crain.realm
